# Banco de dados (Prisma).
# Dev: SQLite local (zero setup). Prod: Postgres do Neon/Supabase.
#   DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL="file:./dev.db"

# Segredo das sessões JWT (cookie httpOnly). Gere um aleatório em prod.
AUTH_SECRET="troque-por-um-segredo-aleatorio-de-32+caracteres"

# Chave do Google Maps / Places API (tela de pesqueiros).
# Hoje a tela usa um mapa placeholder; ao plugar a chave vira Places real.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
